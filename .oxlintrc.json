{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["import", "typescript", "unicorn", "oxc"],
	"categories": {
		"correctness": "error"
	},
	"env": {
		"builtin": true,
		"browser": true,
		"node": true
	},
	"ignorePatterns": ["build/**", ".svelte-kit/**", ".output/**", "node_modules/**", "static/**"],
	"rules": {}
}
